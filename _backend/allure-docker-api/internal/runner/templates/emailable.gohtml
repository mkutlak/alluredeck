<!DOCTYPE html>
<html lang="en">
<head>
    <title>{{.Title}} - Allure Docker Service</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
</head>
<body>
<div class="container mt-4 mb-4">
    <div class="jumbotron">
        <h1 class="display-4">{{.Title}}</h1>
        <p class="lead">Allure Docker Service</p>
        <ul class="list-group mb-3">
            <li class="list-group-item d-flex justify-content-between align-items-center">
                Project ID
                <span class="badge badge-light badge-pill">{{.ProjectID}}</span>
            </li>
            {{if .ServerURL}}
            <li class="list-group-item d-flex justify-content-between align-items-center">
                Server Link
                <span class="badge badge-light badge-pill">
                    <a href="{{.ServerURL}}" target="_blank">{{.ServerURL}}</a>
                </span>
            </li>
            {{end}}
        </ul>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th class="table-active text-center">Total</th>
                        <th class="table-success text-center">Passed</th>
                        <th class="table-danger text-center">Failed</th>
                        <th class="table-warning text-center">Broken</th>
                        <th class="table-light text-center">Skipped</th>
                        <th class="table-dark text-center">Unknown</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="text-center">{{.Stats.Total}}</td>
                        <td class="text-center">{{.Stats.Passed}} ({{printf "%.2f" .Stats.PassedPct}}%)</td>
                        <td class="text-center">{{.Stats.Failed}} ({{printf "%.2f" .Stats.FailedPct}}%)</td>
                        <td class="text-center">{{.Stats.Broken}} ({{printf "%.2f" .Stats.BrokenPct}}%)</td>
                        <td class="text-center">{{.Stats.Skipped}} ({{printf "%.2f" .Stats.SkippedPct}}%)</td>
                        <td class="text-center">{{.Stats.Unknown}} ({{printf "%.2f" .Stats.UnknownPct}}%)</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <hr class="my-4">
        {{range .TestCases}}
        {{$tc := .}}
        <div class="card border-secondary mb-3 {{statusBorderClass .Status}}">
            <div class="card-header">
                {{.Name}}
                <span class="badge badge-pill {{statusBadgeClass .Status}}">{{.Status}}</span>
            </div>
            <div class="card-body">
                <p class="card-text">
                    <b>description:</b> {{.Description}}<br>
                    {{if .Time}}<b>duration:</b> {{formatDurationMs .Time.Duration}} s<br>{{end}}
                    {{if .Extra}}{{if .Extra.Severity}}<b>severity:</b> {{.Extra.Severity}}<br>{{end}}{{end}}
                    {{range .Labels}}{{if isRelevantLabel .Name}}<b>{{.Name}}:</b> {{.Value}}<br>{{end}}{{end}}
                    {{with .TestStage}}
                        {{if .StatusMessage}}<b>Status Message:</b> {{.StatusMessage}}<br>{{end}}
                        {{if .StatusTrace}}<b>Status Trace:</b> {{.StatusTrace}}<br>{{end}}
                    {{end}}
                </p>
                {{with .TestStage}}{{if gt .StepsCount 0}}
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead><tr><th>Steps</th><th>Duration</th></tr></thead>
                        <tbody>
                            {{range $tc.BeforeStages}}{{range .Steps}}
                            <tr class="{{statusTableClass .Status}}">
                                <td>{{.Name}}</td>
                                <td>{{if .Time}}{{formatDurationMs .Time.Duration}}{{else}}0{{end}} s</td>
                            </tr>
                            {{if .StatusMessage}}<tr class="table-danger"><td colspan="2" style="padding-left:3em"><h6>{{.StatusMessage}}</h6></td></tr>{{end}}
                            {{if .StatusTrace}}<tr class="table-danger"><td colspan="2" style="padding-left:3em"><h6>{{.StatusTrace}}</h6></td></tr>{{end}}
                            {{end}}{{end}}
                            {{range .Steps}}
                            <tr class="{{statusTableClass .Status}}">
                                <td>{{.Name}}</td>
                                <td>{{if .Time}}{{formatDurationMs .Time.Duration}}{{else}}0{{end}} s</td>
                            </tr>
                            {{if .StatusMessage}}<tr class="table-danger"><td colspan="2" style="padding-left:3em"><h6>{{.StatusMessage}}</h6></td></tr>{{end}}
                            {{if .StatusTrace}}<tr class="table-danger"><td colspan="2" style="padding-left:3em"><h6>{{.StatusTrace}}</h6></td></tr>{{end}}
                            {{end}}
                            {{range $tc.AfterStages}}{{range .Steps}}
                            <tr class="{{statusTableClass .Status}}">
                                <td>{{.Name}}</td>
                                <td>{{if .Time}}{{formatDurationMs .Time.Duration}}{{else}}0{{end}} s</td>
                            </tr>
                            {{if .StatusMessage}}<tr class="table-danger"><td colspan="2" style="padding-left:3em"><h6>{{.StatusMessage}}</h6></td></tr>{{end}}
                            {{if .StatusTrace}}<tr class="table-danger"><td colspan="2" style="padding-left:3em"><h6>{{.StatusTrace}}</h6></td></tr>{{end}}
                            {{end}}{{end}}
                        </tbody>
                    </table>
                </div>
                {{end}}{{end}}
            </div>
        </div>
        {{end}}
    </div>
</div>
</body>
</html>
