# syntax=docker/dockerfile:1

###### Go Build Stage
FROM --platform=$BUILDPLATFORM golang:1.26-alpine AS build_stage
ARG TARGETOS
ARG TARGETARCH
ARG BUILD_DATE
ARG BUILD_VERSION
ARG BUILD_REF
WORKDIR /build
COPY api/go.mod api/go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download
COPY api/ ./
# Build the Go MCP binary statically with version injection
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH \
    go build -trimpath \
    -ldflags="-s -w \
      -X github.com/mkutlak/alluredeck/api/internal/version.Version=${BUILD_VERSION:-dev} \
      -X github.com/mkutlak/alluredeck/api/internal/version.BuildDate=${BUILD_DATE:-unknown} \
      -X github.com/mkutlak/alluredeck/api/internal/version.BuildRef=${BUILD_REF:-unknown}" \
    -o /app/mcp ./cmd/mcp/

###### Final Image
FROM alpine:3.24
ARG UID=1000
ARG GID=1000

RUN apk add --no-cache \
    ca-certificates \
    tini \
    tzdata \
    && adduser -D -u ${UID} -h /home/allure allure \
    && chown -R ${UID}:${GID} /home/allure

WORKDIR /app

RUN chown -R ${UID}:${GID} /app

# Copy the compiled MCP binary from the build stage
COPY --from=build_stage --chown=${UID}:${GID} /app/mcp /app/mcp

# Volatile build metadata — placed last to avoid busting layer cache
ARG BUILD_DATE
ARG BUILD_VERSION
ARG BUILD_REF
LABEL org.opencontainers.image.created=${BUILD_DATE} \
    org.opencontainers.image.title="alluredeck-mcp" \
    org.opencontainers.image.description="AllureDeck MCP server — Model Context Protocol interface for Allure reports." \
    org.opencontainers.image.licenses="MIT" \
    org.opencontainers.image.version=${BUILD_VERSION} \
    org.opencontainers.image.revision=${BUILD_REF} \
    org.opencontainers.image.source="https://github.com/mkutlak/alluredeck" \
    org.opencontainers.image.url="https://github.com/mkutlak/alluredeck"

ENV PORT=8081

EXPOSE 8081

USER allure

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["/app/mcp"]
