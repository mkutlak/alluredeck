# syntax=docker/dockerfile:1
# ============================================================
# Stage 1 — build
# ============================================================
FROM node:25-alpine AS builder

WORKDIR /app

# Install dependencies first (layer-cached unless lockfile changes)
COPY ui/package.json ui/package-lock.json* ./
RUN --mount=type=cache,target=/root/.npm \
    npm ci --prefer-offline --legacy-peer-deps

# Copy source and build
COPY ui/ .

# Pass dummy build-time values; real values are injected at runtime via env.js
ARG VITE_API_URL=http://localhost:5050
ARG VITE_APP_TITLE="AllureDeck"
ARG VITE_APP_VERSION=dev
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_APP_TITLE=$VITE_APP_TITLE
ENV VITE_APP_VERSION=$VITE_APP_VERSION

RUN npm run build

# ============================================================
# Stage 2 — serve
# ============================================================
FROM nginxinc/nginx-unprivileged:1.29-alpine AS runner

ARG BUILD_DATE
ARG BUILD_VERSION
ARG BUILD_REF

LABEL org.opencontainers.image.created=${BUILD_DATE} \
    org.opencontainers.image.title="AllureDeck UI" \
    org.opencontainers.image.description="Allure Framework is a flexible lightweight multi-language test report tool." \
    org.opencontainers.image.licenses="MIT" \
    org.opencontainers.image.version=${BUILD_VERSION} \
    org.opencontainers.image.revision=${BUILD_REF} \
    org.opencontainers.image.source="https://github.com/mkutlak/alluredeck" \
    org.opencontainers.image.url="https://github.com/mkutlak/alluredeck"

# Switch to root for file operations (nginx-unprivileged defaults to UID 101)
USER root

# Remove default nginx config and copy ours
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

# Copy built assets and rename env.js to template (read-only source for envsubst)
COPY --from=builder /app/dist /usr/share/nginx/html
RUN mv /usr/share/nginx/html/env.js /usr/share/nginx/html/env.js.template

# Copy entrypoint script
COPY docker/docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# Switch back to non-root user
USER nginx

EXPOSE 8080

ENTRYPOINT ["/docker-entrypoint.sh"]
